<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Project_F.Pages.CalendarPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,70">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0" Padding="24,50,24,24">

                <!-- HEADER -->
                <Label Text="Calendar"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       Margin="0,0,0,24"/>

                <!-- CALENDAR CARD -->
                <Border BackgroundColor="#1E1E1E"
                        StrokeThickness="0"
                        Margin="0,0,0,20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <VerticalStackLayout Padding="20,20" Spacing="16">

                        <!-- MONTH NAV -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0"
                                    BackgroundColor="Transparent"
                                    Clicked="OnPrevMonthClicked"
                                    Text="‹"
                                    TextColor="#FF8C00"
                                    FontSize="28"
                                    Padding="0"
                                    WidthRequest="40"
                                    HeightRequest="40"/>

                            <Label Grid.Column="1"
                                   x:Name="MonthLabel"
                                   Text="MAY 2026"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="White"/>

                            <Button Grid.Column="2"
                                    BackgroundColor="Transparent"
                                    Clicked="OnNextMonthClicked"
                                    Text="›"
                                    TextColor="#FF8C00"
                                    FontSize="28"
                                    Padding="0"
                                    WidthRequest="40"
                                    HeightRequest="40"/>
                        </Grid>

                        <!-- WEEKDAY HEADERS -->
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                            <Label Grid.Column="0" Text="Su" FontSize="12" TextColor="#FF8C00" HorizontalOptions="Center"/>
                            <Label Grid.Column="1" Text="Mo" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                            <Label Grid.Column="2" Text="Tu" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                            <Label Grid.Column="3" Text="We" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                            <Label Grid.Column="4" Text="Th" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                            <Label Grid.Column="5" Text="Fr" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                            <Label Grid.Column="6" Text="Sa" FontSize="12" TextColor="#FF8C00" HorizontalOptions="Center"/>
                        </Grid>

                        <!-- CALENDAR DAYS -->
                        <Grid x:Name="CalendarGrid"
                              ColumnDefinitions="*,*,*,*,*,*,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="4"
                              ColumnSpacing="4"/>

                    </VerticalStackLayout>
                </Border>

                <!-- SELECTED DATE + SUMMARY -->
                <Border BackgroundColor="#1E1E1E"
                        StrokeThickness="0"
                        Margin="0,0,0,16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="20,16" Spacing="4">
                        <Label x:Name="DateLabel"
                               Text="Select a date"
                               FontSize="13"
                               TextColor="#888888"
                               HorizontalOptions="Center"/>
                        <Label x:Name="TotalAmountLabel"
                               Text="₱0.00"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label x:Name="SummaryLabel"
                               Text="No transactions"
                               FontSize="12"
                               TextColor="#666"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- TRANSACTION LIST FOR SELECTED DATE -->
                <CollectionView x:Name="DayTransactionCollection">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1E1E1E" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="44,*,Auto"
                                      Padding="14,14"
                                      ColumnSpacing="12">

                                    <Border Grid.Column="0"
                                            BackgroundColor="#2A2A2A"
                                            WidthRequest="44"
                                            HeightRequest="44">
                                        <Border.StrokeShape>
                                            <Ellipse/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding TypeIcon}"
                                               FontSize="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="3"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Title}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                        <Label Text="{Binding Type}"
                                               FontSize="11"
                                               TextColor="#666666"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayAmount}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{Binding AmountColor}"
                                           VerticalOptions="Center"/>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV BAR -->
        <Grid Grid.Row="1"
              BackgroundColor="#181818"
              ColumnDefinitions="*,*,*">

            <BoxView Grid.ColumnSpan="3"
                     Color="#FF8C00"
                     HeightRequest="1"
                     VerticalOptions="Start"
                     Opacity="0.4"/>

            <Button Grid.Column="0"
                    BackgroundColor="Transparent"
                    Clicked="OnHomeClicked"
                    ImageSource="home.png"
                    HeightRequest="50"/>

            <Button Grid.Column="1"
                    BackgroundColor="Transparent"
                    Clicked="OnCalendarClicked"
                    ImageSource="calendar.png"
                    HeightRequest="50"/>

            <Button Grid.Column="2"
                    BackgroundColor="Transparent"
                    Clicked="OnProfileClicked"
                    ImageSource="profile.png"
                    HeightRequest="50"/>

        </Grid>

    </Grid>
</ContentPage>