<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Project_F.Models"
             x:Class="Project_F.Pages.HomePage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False"
             Title="Finance Tracker">

    <Grid RowDefinitions="*,70">

        <!-- SCROLLABLE CONTENT -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0" Padding="24,50,24,24">

                <!-- HEADER ROW -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,28">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Good day 👋"
                               FontSize="13"
                               TextColor="#888888"/>
                        <Label x:Name="WelcomeLabel"
                               Text="Welcome back"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="#FF8C00"
                            WidthRequest="42"
                            HeightRequest="42"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <Ellipse/>
                        </Border.StrokeShape>
                        <Label Text="M"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- BALANCE CARD -->
                <Border Margin="0,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF8C00" Offset="0.0"/>
                            <GradientStop Color="#CC5500" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#FF8C00" Offset="0,8" Radius="20" Opacity="0.35"/>
                    </Border.Shadow>
                    <VerticalStackLayout Padding="28,28" Spacing="6">
                        <Label Text="TOTAL BALANCE"
                               FontSize="11"
                               TextColor="#FFE0B2"
                               CharacterSpacing="2"
                               HorizontalOptions="Center"/>
                        <Label x:Name="BalanceLabel"
                               Text="₱0.00"
                               FontSize="42"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label Text="Updated just now"
                               FontSize="11"
                               TextColor="#FFE0B2"
                               HorizontalOptions="Center"
                               Opacity="0.7"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ADD / MINUS BUTTONS -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,0,0,32">

                    <Border Grid.Column="0"
                            BackgroundColor="#1E1E1E"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Button Text="＋  Add"
                                Clicked="OnAddFundsClicked"
                                BackgroundColor="Transparent"
                                TextColor="#FF8C00"
                                FontSize="15"
                                FontAttributes="Bold"
                                HeightRequest="56"/>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#1E1E1E"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Button Text="－  Minus"
                                Clicked="OnMinusFundsClicked"
                                BackgroundColor="Transparent"
                                TextColor="#FF8C00"
                                FontSize="15"
                                FontAttributes="Bold"
                                HeightRequest="56"/>
                    </Border>

                </Grid>

                <!-- TRANSACTIONS HEADER -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                    <Label Grid.Column="0"
                           Text="Transactions"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="See all"
                           FontSize="12"
                           TextColor="#FF8C00"
                           VerticalOptions="Center"/>
                </Grid>

                <!-- TRANSACTION LIST -->
                <CollectionView x:Name="TransactionCollection"
                                Margin="0,0,0,20">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TransactionModel">
                            <Border BackgroundColor="#1E1E1E"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.25"/>
                                </Border.Shadow>
                                <Grid ColumnDefinitions="44,*,Auto"
                                      Padding="14,14"
                                      ColumnSpacing="12">

                                    <Border Grid.Column="0"
                                            BackgroundColor="#2A2A2A"
                                            WidthRequest="44"
                                            HeightRequest="44">
                                        <Border.StrokeShape>
                                            <Ellipse/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding TypeIcon}"
                                               FontSize="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="3"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Title}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                        <Label Text="{Binding Type}"
                                               FontSize="11"
                                               TextColor="#666666"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayAmount}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{Binding AmountColor}"
                                           VerticalOptions="Center"/>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- FUNDS POPUP OVERLAY -->
        <Grid Grid.Row="0"
              x:Name="FundsOverlay"
              IsVisible="False"
              BackgroundColor="#CC000000">
            <Border BackgroundColor="#1E1E1E"
                    StrokeThickness="1.5"
                    Stroke="#FF8C00"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="320">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <VerticalStackLayout Padding="28" Spacing="16">

                    <Label x:Name="PopupTitle"
                           Text="Funds"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1"
                             Color="#FF8C00"
                             Opacity="0.3"/>

                    <Border BackgroundColor="#2A2A2A"
                            StrokeThickness="1"
                            Stroke="#FF8C00">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="FundsAmountEntry"
                               Placeholder="Enter amount"
                               PlaceholderColor="#555"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               Keyboard="Numeric"
                               HeightRequest="50"
                               FontSize="16"
                               Margin="14,0"/>
                    </Border>

                    <Border BackgroundColor="#2A2A2A"
                            StrokeThickness="1"
                            Stroke="#FF8C00">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="FundsDescriptionEntry"
                               Placeholder="Description (optional)"
                               PlaceholderColor="#555"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               HeightRequest="50"
                               FontSize="14"
                               Margin="14,0"/>
                    </Border>

                    <Label Text="Choose an icon"
                           FontSize="12"
                           TextColor="#888888"
                           Margin="0,0,0,-8"/>

                    <Border BackgroundColor="#2A2A2A"
                            StrokeThickness="1"
                            Stroke="#FF8C00"
                            HorizontalOptions="Center"
                            WidthRequest="56"
                            HeightRequest="56">
                        <Border.StrokeShape>
                            <Ellipse/>
                        </Border.StrokeShape>
                        <Label x:Name="SelectedIconLabel"
                               Text="💰"
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="10" Padding="4,0">

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="🍔" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="🍔"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="🏠" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="🏠"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="🚗" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="🚗"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="💊" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="💊"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="🛒" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="🛒"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="🎮" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="🎮"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="✈️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="✈️"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="💼" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="💼"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="💰" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="💰"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="🎓" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="🎓"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="💡" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="💡"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <Border BackgroundColor="#2A2A2A" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="🏋️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIconSelected" CommandParameter="🏋️"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                        </HorizontalStackLayout>
                    </ScrollView>

                    <Button Text="Confirm"
                            Clicked="OnUpdateFundsClicked"
                            BackgroundColor="#FF8C00"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            HeightRequest="50"
                            FontSize="15"/>

                    <Button Text="Cancel"
                            Clicked="OnCancelFundsClicked"
                            BackgroundColor="Transparent"
                            TextColor="#666666"
                            BorderColor="#2A2A2A"
                            BorderWidth="1"
                            CornerRadius="14"
                            HeightRequest="50"
                            FontSize="15"/>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- BOTTOM NAV BAR -->
        <Grid Grid.Row="1"
              BackgroundColor="#181818"
              ColumnDefinitions="*,*,*">

            <BoxView Grid.ColumnSpan="3"
                     Color="#FF8C00"
                     HeightRequest="1"
                     VerticalOptions="Start"
                     Opacity="0.4"/>

            <Button Grid.Column="0"
                    x:Name="HomeNavButton"
                    BackgroundColor="Transparent"
                    Clicked="OnHomeClicked"
                    ImageSource="home.png"
                    HeightRequest="50"/>

            <Button Grid.Column="1"
                    x:Name="CalendarNavButton"
                    BackgroundColor="Transparent"
                    Clicked="OnCalendarClicked"
                    ImageSource="calendar.png"
                    HeightRequest="50"/>

            <Button Grid.Column="2"
                    x:Name="ProfileNavButton"
                    BackgroundColor="Transparent"
                    Clicked="OnProfileClicked"
                    ImageSource="profile.png"
                    HeightRequest="50"/>

        </Grid>

    </Grid>

</ContentPage>