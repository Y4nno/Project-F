<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Project_F.Models"
             x:Class="Project_F.Pages.HomePage"
             BackgroundColor="#1D1D1D"
             Shell.NavBarIsVisible="False"
             Title="Finance Tracker">

    <Grid RowDefinitions="*,70">

        <!-- SCROLLABLE CONTENT -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0" Padding="20,40,20,20">

                <!-- WELCOME -->
                <Label Text="Welcome"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20"/>

                <!-- BALANCE CARD -->
                <Border BackgroundColor="#1A1A1A"
                        StrokeThickness="1.5"
                        Stroke="#FF8C00"
                        Margin="0,0,0,20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="20,20" Spacing="8">
                        <Label Text="Current Balance"
                               FontSize="13"
                               TextColor="#FF8C00"
                               HorizontalOptions="Center"/>
                        <Label x:Name="BalanceLabel"
                               Text="₱0.00"
                               FontSize="38"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <BoxView HeightRequest="1"
                                 Color="#FF8C00"
                                 Opacity="0.4"
                                 Margin="20,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ADD / MINUS BUTTONS -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,0,0,30">
                    <Button Grid.Column="0"
                            Text="Add Funds"
                            Clicked="OnAddFundsClicked"
                            BackgroundColor="Transparent"
                            TextColor="#FF8C00"
                            BorderColor="#FF8C00"
                            BorderWidth="1.5"
                            CornerRadius="25"
                            FontSize="14"
                            HeightRequest="48"/>
                    <Button Grid.Column="1"
                            Text="Minus Funds"
                            Clicked="OnMinusFundsClicked"
                            BackgroundColor="Transparent"
                            TextColor="#FF8C00"
                            BorderColor="#FF8C00"
                            BorderWidth="1.5"
                            CornerRadius="25"
                            FontSize="14"
                            HeightRequest="48"/>
                </Grid>

                <!-- TRANSACTIONS HEADER -->
                <Label Text="Transactions"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10"/>

                <!-- TRANSACTION LIST -->
                <CollectionView x:Name="TransactionCollection"
                                Margin="0,0,0,20">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TransactionModel">
                            <Border BackgroundColor="#1A1A1A"
                                    StrokeThickness="0.5"
                                    Stroke="#2A2A2A">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto"
                                      Padding="16,12">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Title}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#FF8C00"/>
                                        <Label Text="{Binding Type}"
                                               FontSize="11"
                                               TextColor="#888888"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayAmount}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- FUNDS POPUP OVERLAY -->
        <Grid Grid.Row="0"
          x:Name="FundsOverlay"
          IsVisible="False"
          BackgroundColor="#CC000000">
            <Border BackgroundColor="#1A1A1A"
                StrokeThickness="1.5"
                Stroke="#FF8C00"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <VerticalStackLayout Padding="24" Spacing="16">

                    <Label x:Name="PopupTitle"
                       Text="Funds"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1"
                         Color="#FF8C00"
                         Opacity="0.4"
                         Margin="10,0"/>

                    <Border BackgroundColor="Transparent"
                        StrokeThickness="1"
                        Stroke="#FF8C00">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25"/>
                        </Border.StrokeShape>
                        <Entry x:Name="FundsAmountEntry"
                           Placeholder="Enter amount"
                           PlaceholderColor="#666"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           Keyboard="Numeric"
                           HeightRequest="48"
                           Margin="12,0"/>
                    </Border>

                    <Button Text="Update"
                        Clicked="OnUpdateFundsClicked"
                        BackgroundColor="Transparent"
                        TextColor="#FF8C00"
                        BorderColor="#FF8C00"
                        BorderWidth="1.5"
                        CornerRadius="25"
                        HeightRequest="48"
                        FontSize="15"/>

                    <Button Text="Cancel"
                        Clicked="OnCancelFundsClicked"
                        BackgroundColor="Transparent"
                        TextColor="#FF8C00"
                        BorderColor="#FF8C00"
                        BorderWidth="1.5"
                        CornerRadius="25"
                        HeightRequest="48"
                        FontSize="15"/>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- BOTTOM NAV BAR -->
        <Grid Grid.Row="1"
              BackgroundColor="#1F1F1F"
              ColumnDefinitions="*,*,*">

            <BoxView Grid.ColumnSpan="3"
                     Color="#FF9800"
                     HeightRequest="2"
                     VerticalOptions="Start"/>

            <Button Grid.Column="0"
                    x:Name="HomeNavButton"
                    BackgroundColor="Transparent"
                    Clicked="OnHomeClicked"
                    ImageSource="home.png"
                    HeightRequest="50"/>

            <Button Grid.Column="1"
                    x:Name="CalendarNavButton"
                    BackgroundColor="Transparent"
                    Clicked="OnCalendarClicked"
                    ImageSource="calendar.png"
                    HeightRequest="50"/>

            <Button Grid.Column="2"
                    x:Name="ProfileNavButton"
                    BackgroundColor="Transparent"
                    Clicked="OnProfileClicked"
                    ImageSource="profile.png"
                    HeightRequest="50"/>

        </Grid>

    </Grid>

</ContentPage>